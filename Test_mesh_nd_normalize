"""
tests/test_mesh_nd_normalize.py

Tests for normalize_counts() and get_peaks() in MeshND.
Run with: pytest -q
"""
from algos.mesh import MeshND


def test_normalize_zero_small_and_divide_large():
    mesh = MeshND(bounds=[(0, 1), (0, 1)], cells=[5, 5])
    mesh._set_at((2, 2), 10.0)   # big
    mesh._set_at((0, 0), 0.0001) # tiny noise
    mesh._set_at((4, 4), 0.5)    # medium
    mesh._set_at((1, 3), 0.02)   # small but above tiny noise

    # apply normalize: zero below 0.01, divide above 1.0 by 5
    mesh.normalize_counts(low_threshold=0.01, zero_small=True, high_threshold=1.0, divide_const=5.0)

    assert mesh._get_at((0, 0)) == 0.0
    assert abs(mesh._get_at((2, 2)) - 2.0) < 1e-12
    assert abs(mesh._get_at((4, 4)) - 0.5) < 1e-12
    assert abs(mesh._get_at((1, 3)) - 0.02) < 1e-12


def test_get_peaks_simple():
    mesh = MeshND(bounds=[(0, 1), (0, 1)], cells=[3, 3])
    mesh._set_at((1, 1), 5.0)
    mesh._set_at((0, 1), 3.0)
    mesh._set_at((2, 1), 2.0)
    mesh._set_at((1, 0), 1.0)

    peaks = mesh.get_peaks(min_value=1.0, neighborhood=1)
    assert any(idx == (1, 1) for idx, v in peaks)
    assert len(peaks) == 1
